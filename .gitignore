# =============================================================================
# Sudoku Solver — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
htmlcov/
.pytest_cache/
nosetests.xml

# Typing
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Ruff
.ruff_cache/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env
.venv.bak/
venv.bak/

# -----------------------------------------------------------------------------
# IDEs and editors
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist
Session.vim

# Emacs
*#
.\#*
.dir-locals.el

# Sublime Text
*.sublime-project
*.sublime-workspace

# Spyder
.spyderproject.db
.spyproject

# Rope
.ropeproject

# -----------------------------------------------------------------------------
# OS artefacts
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# Linux
*~

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------

# Local puzzle scratch files (keep only committed puzzles)
puzzles/local/
puzzles/scratch/

# pygame screenshots / recordings saved by the app
screenshots/
recordings/

# Profiling output
*.prof
*.lprof

# Jupyter notebooks (not part of this project)
*.ipynb
.ipynb_checkpoints/

# Secrets / local config overrides
.env.local
config.local.toml

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.bak
*.tmp
*.orig
.hypothesis/
